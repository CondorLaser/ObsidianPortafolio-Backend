# Selector de ambiente. dev = local Docker; prod = Render/Neon.
APP_ENV=dev

# DB para dev local (Docker en :5433). Solo se usa cuando APP_ENV=dev y no hay DATABASE_URL.
DATABASE_URL_DEV=postgresql+asyncpg://orion:orion@localhost:5433/orion_dev

# Override explícito. Si está seteada, gana sobre APP_ENV.
# Render/Neon: ponla acá (asyncpg-compatible, sin ?sslmode=...).
# DATABASE_URL=postgresql+asyncpg://neondb_owner:...@ep-xxx-pooler.<region>.aws.neon.tech/neondb

CLERK_ISSUER=https://your-tenant.clerk.accounts.dev
ALLOWED_ORIGINS=http://localhost:3000
